-- // SILENT AIM LOGIC (LAG-FREE)
local OldNamecall
OldNamecall = hookmetamethod(game, "__namecall", function(Self, ...)
    local Method = getnamecallmethod()
    if SilentAimActive and (Method == "FindPartOnRayWithIgnoreList" or Method == "Raycast") then
        -- Only run if holding a tool (Fixes weapon switch lag)
        if LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Tool") then
            local Center = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
            local Target = nil
            local Dist = FOVRadius
            for _, p in pairs(Players:GetPlayers()) do
                if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("Head") then
                    local Pos, OnScreen = Camera:WorldToViewportPoint(p.Character.Head.Position)
                    if OnScreen then
                        local Mag = (Vector2.new(Pos.X, Pos.Y) - Center).Magnitude
                        if Mag < Dist then Dist = Mag Target = p end
                    end
                end
            end
            if Target then return Target.Character.Head, Target.Character.Head.Position end
        end
    end
    return OldNamecall(Self, ...)
end)

